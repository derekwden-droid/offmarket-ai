# OffMarket.AI — environment template
# Copy to .env.local for local dev, or set these in the Vercel project.
# NEVER commit a filled-in copy: .gitignore ignores every .env* except this file.
# All provider integrations are fail-closed: unset keys block the relevant
# action rather than sending/scrubbing silently.

# ── Database (Supabase Postgres) ─────────────────────────────────────────
# Pooled runtime connection (Supavisor / PgBouncer, port 6543).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used only by `prisma migrate`.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Internal API auth (Phase 0) ──────────────────────────────────────────
# Shared secret gating every /api/* route except the self-authenticating ones.
INTERNAL_API_SECRET=""

# ── Skip-trace provider (Phase 2) ────────────────────────────────────────
# When unset, a deterministic address-seeded simulator is used.
SKIPTRACE_API_URL=""
SKIPTRACE_API_KEY=""

# ── Property + public-records ingestion (Phase 3) ────────────────────────
PROPERTY_DATA_API_URL=""
PROPERTY_DATA_API_KEY=""
PUBLIC_RECORDS_API_URL=""
PUBLIC_RECORDS_APP_TOKEN=""
PUBLIC_RECORDS_SOURCE_LABEL=""
# HMAC secret signing inbound POST /api/scrape webhook payloads.
SCRAPE_WEBHOOK_SECRET=""

# ── Background queue (Inngest, Phase 2) ──────────────────────────────────
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# ── SMS provider (Phase 4/5) ─────────────────────────────────────────────
# Pick one provider; creds left blank keep the send path fail-closed.
SMS_PROVIDER=""            # "twilio" | "telnyx" (inferred from creds if blank)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TELNYX_API_KEY=""
TELNYX_MESSAGING_PROFILE_ID=""
# Inbound webhook signature verification.
TELNYX_PUBLIC_KEY=""
INBOUND_SMS_WEBHOOK_URL=""

# ── DNC scrubbing (Phase 4) — blocks sends when unset ────────────────────
DNC_API_URL=""
DNC_API_KEY=""

# ── Email provider (Resend, Phase 5) ─────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM=""              # e.g. "OffMarket <outreach@mail.example.com>"
# Signs one-click CAN-SPAM unsubscribe links.
UNSUBSCRIBE_SECRET=""
APP_BASE_URL="https://offmarket-ai.vercel.app"

# ── AI agent (Anthropic Claude, Phase 5) ─────────────────────────────────
ANTHROPIC_API_KEY=""
AGENT_MODEL="claude-sonnet-4-6"

# ── Observability (Phase 6) ──────────────────────────────────────────────
# Error tracking. When unset, capture is a silent no-op (fail-open).
SENTRY_DSN=""
SENTRY_ENVIRONMENT=""      # defaults to VERCEL_ENV / NODE_ENV
SENTRY_RELEASE=""          # defaults to VERCEL_GIT_COMMIT_SHA
LOG_LEVEL="info"           # debug | info | warn | error

# ── Rate limiting on public routes (Phase 6) ─────────────────────────────
RATE_LIMIT_ENABLED="true"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="60"
