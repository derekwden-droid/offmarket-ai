// OffMarket.AI — Prisma schema
// Provider: Supabase Postgres. `directUrl` is used by Prisma Migrate (direct 5432),
// while `url` is the pooled runtime connection (PgBouncer 6543).

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum LeadStatus {
  RAW
  SKIP_TRACED
  AI_CONTACTED
  QUALIFIED
  COLD
}

enum Channel {
  SMS
  EMAIL
}

enum SuppressionReason {
  STOP
  DNC
  BOUNCE
  MANUAL
}

enum MessageDirection {
  IN
  OUT
}

enum ConversationState {
  NEW
  CONTACTED
  ENGAGED
  QUALIFIED
  COLD
  OPTED_OUT
}

enum SkipTraceJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum DraftStatus {
  PENDING
  APPROVED
  REJECTED
}

enum VacancyStatus {
  UNKNOWN
  CONFIRMED_VACANT
  PROBABLE_VACANT
  UNCERTAIN
  NOT_VACANT
}

enum DealStage {
  INGESTED
  ENRICHED
  VERIFIED_VACANT
  SKIPTRACE_READY
  SKIP_TRACED
  OUTREACH_READY
  AI_CONTACTED
  QUALIFIED
  UNDERWRITTEN
  DEAD
}

model Property {
  id           String     @id @default(uuid())
  address      String
  city         String
  state        String
  zip          String
  propertyType String
  zoning       String?
  ownerName    String?
  ownerPhone   String?
  ownerEmail   String?
  scrapeSource String
  status       LeadStatus @default(RAW)
  aiNotes      String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  apn              String?
  lat              Float?
  lng              Float?
  parcelGeometry   Json?
  landUseCode      String?
  dealStage        DealStage       @default(INGESTED)

  listPackages   ListPackage[] @relation("ListToProperties")
  consentRecords ConsentRecord[]
  conversations  Conversation[]
  vacancyVerification VacancyVerification?

  @@unique([address, city, state, zip], name: "property_location")
  @@index([status])
  @@index([state])
  @@index([scrapeSource])
  @@index([createdAt])
  @@index([dealStage])
}

model ListPackage {
  id          String     @id @default(uuid())
  name        String
  description String
  price       Float
  properties  Property[] @relation("ListToProperties")
  createdAt   DateTime   @default(now())
}

model ConsentRecord {
  id                 String   @id @default(uuid())
  propertyId         String
  property           Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel            Channel
  consentTextVersion String
  source             String
  ipAddress          String?
  createdAt          DateTime @default(now())

  @@index([propertyId])
  @@index([channel])
}

model Suppression {
  id        String            @id @default(uuid())
  value     String
  channel   Channel
  reason    SuppressionReason
  detail    String?
  createdAt DateTime          @default(now())

  @@unique([value, channel], name: "suppression_identity")
  @@index([value])
}

model Conversation {
  id             String            @id @default(uuid())
  propertyId     String
  property       Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  channel        Channel
  state          ConversationState @default(NEW)
  assignedNumber String?
  paused         Boolean           @default(false)
  messages       Message[]
  drafts         AgentDraft[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([propertyId])
  @@index([state])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  direction      MessageDirection
  body           String
  providerSid    String?
  status         String?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([providerSid])
}

model AgentDraft {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  propertyId     String
  channel        Channel
  body           String
  proposedState  ConversationState
  reasoning      String?
  qualified      Boolean      @default(false)
  status         DraftStatus  @default(PENDING)
  providerSid    String?
  createdAt      DateTime     @default(now())
  decidedAt      DateTime?

  @@index([status])
  @@index([conversationId])
}

model SkipTraceJob {
  id        String            @id @default(uuid())
  status    SkipTraceJobStatus @default(PENDING)
  total     Int               @default(0)
  completed Int               @default(0)
  failed    Int               @default(0)
  createdAt DateTime          @default(now())
  finishedAt DateTime?

  @@index([status])
}

model AgentConfig {
  id             String   @id @default(uuid())
  tone           String
  objectives     String[]
  channels       Channel[]
  scriptTemplate String
  thresholds     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ComplianceConfig {
  id                   String   @id @default(uuid())
  sendingEnabled       Boolean  @default(false)
  businessName         String
  physicalAddress      String
  supportEmail         String
  smsFromNumber        String?
  quietHoursStart      Int      @default(8)
  quietHoursEnd        Int      @default(20)
  dailyCapPerRecipient Int      @default(3)
  consentTextVersion   String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model VacancyVerification {
  id                       String        @id @default(uuid())
  propertyId               String        @unique
  property                   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  assessorVacantFlag       Boolean?
  buildingFootprintFlag    Boolean?
  imageryProvider          String?
  imageryCapturedAt        DateTime?
  structureDetected        Boolean?
  imageryEvidence          Json?

  vacancyStatus            VacancyStatus @default(UNKNOWN)
  vacancyConfidence        Float         @default(0)
  reviewRequired           Boolean       @default(false)
  reviewReason             String?

  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
}
